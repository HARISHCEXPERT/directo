{
  "manifest_version": 3,
  "name": "Directo — AI Launch Autofill",
  "version": "0.4.3",
  "description": "AI auto-fills any SaaS directory submission form. Auto-detects when your listing is approved. By Directo.",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "notifications", "alarms"],
  "host_permissions": [
    "https://*.producthunt.com/*",
    "https://*.betalist.com/*",
    "https://*.saashub.com/*",
    "https://*.alternativeto.net/*",
    "https://*.indiehackers.com/*",
    "https://*.uneed.best/*",
    "https://*.toolify.ai/*",
    "https://*.theresanaiforthat.com/*",
    "https://*.startupbase.io/*",
    "https://*.launching.today/*",
    "https://*.tinylaunch.com/*",
    "https://*.fazier.com/*",
    "https://*.peerlist.io/*",
    "https://*.starterstory.com/*",
    "https://*.allthingsai.com/*",
    "https://*.futuretools.io/*",
    "https://*.aitoolhunt.com/*",
    "https://*.toolpilot.ai/*",
    "https://*.illustration.ai/*",
    "https://*.opentools.ai/*",
    "https://dicrecto.vercel.app/*",
    "https://*.directo.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Directo — AI autofill"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.producthunt.com/*",
        "https://*.betalist.com/*",
        "https://*.saashub.com/*",
        "https://*.alternativeto.net/*",
        "https://*.indiehackers.com/*",
        "https://*.uneed.best/*",
        "https://*.toolify.ai/*",
        "https://*.theresanaiforthat.com/*",
        "https://*.startupbase.io/*",
        "https://*.launching.today/*",
        "https://*.tinylaunch.com/*",
        "https://*.fazier.com/*",
        "https://*.peerlist.io/*",
        "https://*.starterstory.com/*",
        "https://*.allthingsai.com/*",
        "https://*.futuretools.io/*",
        "https://*.aitoolhunt.com/*",
        "https://*.toolpilot.ai/*",
        "https://*.illustration.ai/*",
        "https://*.opentools.ai/*"
      ],
      "js": [
        "lib/fill-helpers.js",
        "lib/directories.js",
        "content/scanner.js",
        "content/ai-filler.js",
        "content/approval-detector.js",
        "content/overlay.js"
      ],
      "css": ["content/overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
